#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <HTTPClient.h>
#include "esp_http_server.h"
#include "img_converters.h"

// =====================================================
// DATOS DE TU RED WIFI
// =====================================================
const char* ssid = "NOMBRE_DE_TU_WIFI";
const char* password = "CONTRASEÑA_DE_TU_WIFI";

// =====================================================
// DATOS DE FIREBASE / FIRESTORE
// =====================================================
// Reemplaza estos valores con los de tu proyecto Firebase
String firebaseProjectId = "TU_PROJECT_ID";
String firebaseApiKey = "TU_WEB_API_KEY";

// Documento del cajón que va a controlar esta ESP32-CAM
String cajonId = "A-01";

// =====================================================
// PINES ESP32-CAM AI THINKER
// NO CAMBIAR
// =====================================================
#define PWDN_GPIO_NUM     32
#define RESET_GPIO_NUM    -1
#define XCLK_GPIO_NUM      0
#define SIOD_GPIO_NUM     26
#define SIOC_GPIO_NUM     27

#define Y9_GPIO_NUM       35
#define Y8_GPIO_NUM       34
#define Y7_GPIO_NUM       39
#define Y6_GPIO_NUM       36
#define Y5_GPIO_NUM       21
#define Y4_GPIO_NUM       19
#define Y3_GPIO_NUM       18
#define Y2_GPIO_NUM        5

#define VSYNC_GPIO_NUM    25
#define HREF_GPIO_NUM     23
#define PCLK_GPIO_NUM     22

// =====================================================
// SERVIDORES HTTP PARA LA CÁMARA
// =====================================================
httpd_handle_t camera_httpd = NULL;
httpd_handle_t stream_httpd = NULL;

#define PART_BOUNDARY "123456789000000000000987654321"

static const char* STREAM_CONTENT_TYPE =
  "multipart/x-mixed-replace;boundary=" PART_BOUNDARY;

static const char* STREAM_BOUNDARY =
  "\r\n--" PART_BOUNDARY "\r\n";

static const char* STREAM_PART =
  "Content-Type: image/jpeg\r\nContent-Length: %u\r\n\r\n";

// =====================================================
// FUNCIÓN PARA ACTUALIZAR FIREBASE FIRESTORE
// Actualiza únicamente el campo booleano: disponible
// =====================================================
void actualizarFirebase(bool disponible) {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("No hay conexion WiFi. No se pudo actualizar Firebase.");
    return;
  }

  WiFiClientSecure client;

  // Para proyecto universitario/prueba.
  // Evita problemas de certificado SSL en ESP32.
  client.setInsecure();

  HTTPClient http;

  String url = "https://firestore.googleapis.com/v1/projects/";
  url += firebaseProjectId;
  url += "/databases/(default)/documents/cajones_estacionamiento/";
  url += cajonId;
  url += "?key=";
  url += firebaseApiKey;
  url += "&updateMask.fieldPaths=disponible";

  String valorBooleano = disponible ? "true" : "false";

  String body = "{";
  body += "\"fields\":{";
  body += "\"disponible\":{";
  body += "\"booleanValue\":";
  body += valorBooleano;
  body += "}";
  body += "}";
  body += "}";

  Serial.println("------------------------------------");
  Serial.println("Actualizando Firebase...");
  Serial.print("Cajon: ");
  Serial.println(cajonId);
  Serial.print("Disponible: ");
  Serial.println(disponible ? "true" : "false");

  http.begin(client, url);
  http.addHeader("Content-Type", "application/json");

  int httpResponseCode = http.PATCH(body);

  Serial.print("Codigo HTTP Firebase: ");
  Serial.println(httpResponseCode);

  String respuesta = http.getString();
  Serial.println("Respuesta Firebase:");
  Serial.println(respuesta);

  http.end();
  Serial.println("------------------------------------");
}

// =====================================================
// PÁGINA PRINCIPAL DEL STREAM
// =====================================================
static esp_err_t index_handler(httpd_req_t *req) {
  String html = "";

  html += "<!DOCTYPE html>";
  html += "<html>";
  html += "<head>";
  html += "<meta name='viewport' content='width=device-width, initial-scale=1'>";
  html += "<title>ESP32-CAM Smart Campus UPSLP</title>";
  html += "<style>";
  html += "body{font-family:Arial;text-align:center;background:#111;color:white;}";
  html += "img{width:95%;max-width:720px;border-radius:12px;}";
  html += "a{color:#00c3ff;font-size:20px;}";
  html += "</style>";
  html += "</head>";
  html += "<body>";
  html += "<h2>ESP32-CAM Smart Campus UPSLP</h2>";
  html += "<p>Stream de video en vivo</p>";
  html += "<img src='http://";
  html += WiFi.localIP().toString();
  html += ":81/stream'>";
  html += "<p><a href='http://";
  html += WiFi.localIP().toString();
  html += ":81/stream'>Abrir stream directo</a></p>";
  html += "</body>";
  html += "</html>";

  httpd_resp_set_type(req, "text/html");
  return httpd_resp_send(req, html.c_str(), html.length());
}

// =====================================================
// STREAM DE VIDEO
// =====================================================
static esp_err_t stream_handler(httpd_req_t *req) {
  camera_fb_t *fb = NULL;
  esp_err_t res = ESP_OK;

  size_t jpg_buf_len = 0;
  uint8_t *jpg_buf = NULL;
  char part_buf[64];

  res = httpd_resp_set_type(req, STREAM_CONTENT_TYPE);

  if (res != ESP_OK) {
    return res;
  }

  while (true) {
    fb = esp_camera_fb_get();

    if (!fb) {
      Serial.println("Error: no se pudo obtener imagen de la camara");
      res = ESP_FAIL;
    } else {
      if (fb->format != PIXFORMAT_JPEG) {
        bool converted = frame2jpg(fb, 80, &jpg_buf, &jpg_buf_len);
        esp_camera_fb_return(fb);
        fb = NULL;

        if (!converted) {
          Serial.println("Error: no se pudo convertir imagen a JPG");
          res = ESP_FAIL;
        }
      } else {
        jpg_buf_len = fb->len;
        jpg_buf = fb->buf;
      }
    }

    if (res == ESP_OK) {
      res = httpd_resp_send_chunk(req, STREAM_BOUNDARY, strlen(STREAM_BOUNDARY));
    }

    if (res == ESP_OK) {
      size_t hlen = snprintf(part_buf, sizeof(part_buf), STREAM_PART, jpg_buf_len);
      res = httpd_resp_send_chunk(req, part_buf, hlen);
    }

    if (res == ESP_OK) {
      res = httpd_resp_send_chunk(req, (const char *)jpg_buf, jpg_buf_len);
    }

    if (fb) {
      esp_camera_fb_return(fb);
      fb = NULL;
      jpg_buf = NULL;
    } else if (jpg_buf) {
      free(jpg_buf);
      jpg_buf = NULL;
    }

    if (res != ESP_OK) {
      break;
    }
  }

  return res;
}

// =====================================================
// INICIAR SERVIDOR WEB DE LA CÁMARA
// =====================================================
void startCameraServer() {
  httpd_config_t config = HTTPD_DEFAULT_CONFIG();

  httpd_uri_t index_uri;
  index_uri.uri = "/";
  index_uri.method = HTTP_GET;
  index_uri.handler = index_handler;
  index_uri.user_ctx = NULL;

  httpd_uri_t stream_uri;
  stream_uri.uri = "/stream";
  stream_uri.method = HTTP_GET;
  stream_uri.handler = stream_handler;
  stream_uri.user_ctx = NULL;

  // Servidor principal en puerto 80
  config.server_port = 80;

  if (httpd_start(&camera_httpd, &config) == ESP_OK) {
    httpd_register_uri_handler(camera_httpd, &index_uri);
  }

  // Servidor del stream en puerto 81
  config.server_port = 81;
  config.ctrl_port = 32768;

  if (httpd_start(&stream_httpd, &config) == ESP_OK) {
    httpd_register_uri_handler(stream_httpd, &stream_uri);
  }
}

// =====================================================
// SETUP
// =====================================================
void setup() {
  Serial.begin(115200);
  Serial.setDebugOutput(false);
  Serial.println();

  // Configuracion de la camara
  camera_config_t config;

  config.ledc_channel = LEDC_CHANNEL_0;
  config.ledc_timer = LEDC_TIMER_0;

  config.pin_d0 = Y2_GPIO_NUM;
  config.pin_d1 = Y3_GPIO_NUM;
  config.pin_d2 = Y4_GPIO_NUM;
  config.pin_d3 = Y5_GPIO_NUM;
  config.pin_d4 = Y6_GPIO_NUM;
  config.pin_d5 = Y7_GPIO_NUM;
  config.pin_d6 = Y8_GPIO_NUM;
  config.pin_d7 = Y9_GPIO_NUM;

  config.pin_xclk = XCLK_GPIO_NUM;
  config.pin_pclk = PCLK_GPIO_NUM;
  config.pin_vsync = VSYNC_GPIO_NUM;
  config.pin_href = HREF_GPIO_NUM;

  config.pin_sccb_sda = SIOD_GPIO_NUM;
  config.pin_sccb_scl = SIOC_GPIO_NUM;

  config.pin_pwdn = PWDN_GPIO_NUM;
  config.pin_reset = RESET_GPIO_NUM;

  config.xclk_freq_hz = 20000000;
  config.pixel_format = PIXFORMAT_JPEG;

  // Configuracion segun PSRAM disponible
  if (psramFound()) {
    config.frame_size = FRAMESIZE_VGA;
    config.jpeg_quality = 10;
    config.fb_count = 2;
    config.fb_location = CAMERA_FB_IN_PSRAM;
    config.grab_mode = CAMERA_GRAB_LATEST;
  } else {
    config.frame_size = FRAMESIZE_QVGA;
    config.jpeg_quality = 12;
    config.fb_count = 1;
    config.fb_location = CAMERA_FB_IN_DRAM;
    config.grab_mode = CAMERA_GRAB_WHEN_EMPTY;
  }

  // Iniciar camara
  esp_err_t err = esp_camera_init(&config);

  if (err != ESP_OK) {
    Serial.printf("Error al iniciar la camara: 0x%x\n", err);
    return;
  }

  // Conectar a WiFi
  WiFi.begin(ssid, password);
  WiFi.setSleep(false);

  Serial.print("Conectando a WiFi");

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println();
  Serial.println("WiFi conectado");
  Serial.print("IP de la ESP32-CAM: http://");
  Serial.println(WiFi.localIP());

  // Iniciar servidor de camara
  startCameraServer();

  Serial.println("Servidor de camara iniciado");
  Serial.println("Prueba Firebase iniciara desde loop()");
}

// =====================================================
// LOOP DE PRUEBA TEMPORAL
// Cambia disponible cada 5 segundos
// =====================================================
void loop() {
  actualizarFirebase(true);
  delay(5000);

  actualizarFirebase(false);
  delay(5000);
}